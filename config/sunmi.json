{
  "brand": "sunmi",
  "log_file_slug": "sumni",
  "links": [
    {
      "category": "products",
      "url": "https://www.sunmi.com/en/products"
    }
  ],
  "output": {
    "root_dir": "output",
    "save_per_link_files": false,
    "save_combined_file": true,
    "data_root_dir": "output/data",
    "media_root_dir": "media",
    "images_root_dir": "media/images",
    "logs_root_dir": "logs_execution"
  },
  "master_page": {
    "type": "listing",
    "selectors": {
      "product_containers": [
        "section[id] div[class*='ProductSection_product-list'] > a[href^='/en/']"
      ],
      "fields": [
        {
          "key": "manufacturer_category_slug",
          "ancestor_selector": "section[id]",
          "selectors": [
            "section[id]"
          ],
          "mode": "attr",
          "attr": "id",
          "multiple": false
        },
        {
          "key": "manufacturer_category",
          "ancestor_selector": "section[id]",
          "selectors": [
            "section[id]"
          ],
          "mode": "attr",
          "attr": "id",
          "multiple": false,
          "value_map": {
            "cpad": "CPad",
            "interactive-display": "Interactive Display",
            "mobile": "Mobile",
            "payment": "Payment",
            "desktop": "Desktop",
            "kiosks": "Kiosk",
            "network": "Network",
            "accessories": "Accessories"
          }
        },
        {
          "key": "is_accessory",
          "ancestor_selector": "section[id]",
          "selectors": [
            "section[id]"
          ],
          "mode": "attr",
          "attr": "id",
          "multiple": false,
          "value_map": {
            "accessories": true
          },
          "value_map_default": false
        },
        {
          "key": "series",
          "ancestor_selector": "div[class*='ProductSection_series-item']",
          "selectors": [
            "span[class*='ProductSection_title']"
          ],
          "mode": "text",
          "multiple": false
        },
        {
          "key": "series_description",
          "ancestor_selector": "div[class*='ProductSection_series-item']",
          "selectors": [
            "span[class*='ProductSection_content']"
          ],
          "mode": "text",
          "multiple": false
        },
        {
          "key": "name",
          "selectors": [
            "span[class*='ProductSection_name']",
            "a[href]"
          ],
          "mode": "text",
          "multiple": false
        },
        {
          "key": "badge",
          "selectors": [
            "span[class*='ProductSection_suffix']"
          ],
          "mode": "text",
          "multiple": false
        },
        {
          "key": "description",
          "selectors": [
            "span[class*='ProductSection_slogan']",
            "span[class*='ProductSection_category']",
            "p"
          ],
          "mode": "text",
          "multiple": false
        },
        {
          "key": "product_type",
          "selectors": [
            "span[class*='ProductSection_category']"
          ],
          "mode": "text",
          "multiple": false
        },
        {
          "key": "listing_image_url",
          "selectors": [
            "img[src]",
            "img[data-src]"
          ],
          "mode": "attr",
          "attr": "src",
          "multiple": false,
          "normalize_url": true
        },
        {
          "key": "detail_url",
          "selectors": [
            "a[href]"
          ],
          "mode": "attr",
          "attr": "href",
          "multiple": false,
          "normalize_url": true
        }
      ]
    }
  },
  "details_page": {
    "selectors": {
      "product_name": [
        {
          "selector": [
            "h1",
            "h2"
          ],
          "mode": "text",
          "multiple": false
        }
      ]
    },
    "extract": [
      {
        "key": "datasheet_links",
        "mode": "links",
        "selector": "a[href]",
        "include_if_matches": [
          "\\.pdf",
          "datasheet",
          "brochure"
        ],
        "normalize_url": true
      },
      {
        "key": "media_links",
        "mode": "links",
        "selector": "a[href], video[src], source[src], iframe[src]",
        "attrs": [
          "href",
          "src",
          "data-src"
        ],
        "include_if_matches": [
          "\\.mp4",
          "\\.webm",
          "\\.mov",
          "youtube",
          "vimeo",
          "video"
        ],
        "exclude_if_matches": [
          "youtube\\.com/channel",
          "facebook",
          "instagram",
          "linkedin",
          "tiktok",
          "wechat",
          "twitter",
          "x\\.com/"
        ],
        "normalize_url": true
      },
      {
        "key": "feature_paragraphs",
        "container_selector": "main, body",
        "mode": "paired_headings_paragraphs",
        "title_selector": "h2, h3",
        "text_selector": "p"
      }
    ],
    "requires_rendered_dom": true
  },
  "images": {
    "download": true,
    "folders": {
      "path_folder": ""
    },
    "naming": "img_{brand}_{product_name_sanitized}_{index}",
    "sources": [
      {
        "key": "primary_image",
        "container_selectors": [
          "div[data-scraper-no-detail-images]"
        ],
        "image_selectors": [
          "img[src]",
          "img[data-src]"
        ],
        "mode": "attr",
        "attr": "src",
        "multiple": true
      }
    ],
    "allowed_extensions": [
      "jpg",
      "jpeg",
      "png",
      "webp",
      "avif"
    ]
  }
}
